+        if (diag_pump_count < 10) {
+          REXAPU_DEBUG("AudioWorker: callback returned for client {}", index);
+        }
+        diag_pump_count++;
+      } else {
+        REXAPU_DEBUG("AudioWorker: semaphore signaled for client {} but callback is 0", index);
       }
 
       pumped = true;
@@ -188,13 +211,17 @@ void AudioSystem::Shutdown() {
 }
 
